<section class="py-24 bg-white dark:bg-gray-900 transition-colors duration-300 mt-10">
    <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
            <div class="flex items-center justify-center gap-4 mb-8">
                <a href="/" class="bg-white dark:bg-gray-800 p-3 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 text-gray-500 hover:text-primary transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                    </svg>
                </a>
                <h1 class="text-5xl font-bold dark:text-white">
                    <%= aboutContent.title || 'About Us' %>
                </h1>
            </div>

            <div class="rounded-[3rem] overflow-hidden mb-12 shadow-2xl">
                <img src="<%= aboutContent.image || 'https://images.unsplash.com/photo-1560518883-ce09059eeffa?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80' %>"
                    class="w-full h-[500px] object-cover">
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-16 mb-24">
                <div>
                    <h2 class="text-3xl font-bold mb-6 dark:text-white">Our Mission</h2>
                    <p class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed">
                        <%= aboutContent.mission
                            || 'To provide exceptional real estate services through innovation and integrity.' %>
                    </p>
                </div>
                <div>
                    <h2 class="text-3xl font-bold mb-6 dark:text-white">Our Vision</h2>
                    <p class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed">
                        <%= aboutContent.vision || 'To be the most trusted name in luxury real estate worldwide.' %>
                    </p>
                </div>
            </div>

            <div class="prose max-w-none mb-24 dark:prose-invert">
                <h2 class="text-3xl font-bold mb-8 dark:text-white">Who We Are</h2>
                <p class="text-xl text-gray-600 dark:text-gray-300 leading-relaxed">
                    <%= aboutContent.content
                        || 'We are a team of dedicated professionals with decades of experience in the real estate market.'
                        %>
                </p>
            </div>

            <!-- Team -->
            <div>
                <h2 class="text-3xl font-bold mb-12 text-center dark:text-white">Meet Our Experts</h2>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <% agents.forEach(agent=> { %>
                        <div class="text-center">
                        <h3 class="text-xl font-bold mb-1 dark:text-white">
                                <%= agent.name %>
                            </h3>
                            <p class="text-primary font-medium">
                                <%= agent.role %>
                            </p>
                        </div>
                        <% }) %>
                </div>
            </div>
        </div>
    </div>
</section>