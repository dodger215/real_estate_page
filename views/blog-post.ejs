<article class="py-24 bg-white">
    <div class="container mx-auto px-4">
        <div class="max-w-4xl mx-auto">
            <div class="text-center mb-12">
                <div class="flex justify-center items-center gap-4 mb-6">
                    <span class="bg-primary/10 text-primary px-4 py-1 rounded-full text-sm font-bold uppercase">
                        <%= blog.category %>
                    </span>
                    <span class="text-gray-400">
                        <%= new Date(blog.publishedAt).toLocaleDateString() %>
                    </span>
                </div>
                <h1 class="text-5xl font-bold mb-8 leading-tight">
                    <%= blog.title %>
                </h1>
                <div class="flex items-center justify-center gap-4">
                    <div class="w-12 h-12 bg-gray-200 rounded-full overflow-hidden">
                        <img src="https://i.pravatar.cc/100" class="w-full h-full object-cover">
                    </div>
                    <p class="font-bold text-gray-900">By <%= blog.author?.name || 'Admin' %>
                    </p>
                </div>
            </div>

            <div class="rounded-[3rem] overflow-hidden mb-16 shadow-2xl">
                <img src="<%= blog.featuredImage || 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80' %>"
                    class="w-full h-[500px] object-cover">
            </div>

            <div class="prose prose-xl max-w-none text-gray-700 leading-relaxed">
                <%- blog.content %>
            </div>

            <div class="mt-24 pt-12 border-t flex justify-between items-center">
                <div class="flex gap-4">
                    <% (blog.tags || []).forEach(tag=> { %>
                        <span class="text-gray-500 bg-gray-100 px-4 py-1 rounded-full text-sm">#<%= tag %></span>
                        <% }) %>
                </div>
                <div class="flex gap-4">
                    <button
                        class="w-10 h-10 rounded-full border flex items-center justify-center hover:bg-gray-50 transition">
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                            <path
                                d="M24 4.557c-.883.392-1.832.656-2.828.775 1.017-.609 1.798-1.574 2.165-2.724-.951.564-2.005.974-3.127 1.195-.897-.957-2.178-1.555-3.594-1.555-3.179 0-5.515 2.966-4.797 6.045-4.091-.205-7.719-2.165-10.148-5.144-1.29 2.213-.669 5.108 1.523 6.574-.806-.026-1.566-.247-2.229-.616-.054 2.281 1.581 4.415 3.949 4.89-.693.188-1.452.232-2.224.084.626 1.956 2.444 3.379 4.6 3.419-2.07 1.623-4.678 2.348-7.29 2.04 2.179 1.397 4.768 2.212 7.548 2.212 9.142 0 14.307-7.721 13.995-14.646.962-.695 1.797-1.562 2.457-2.549z" />
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </div>
</article>