<section class="py-24 bg-gray-50 dark:bg-gray-900 transition-colors duration-300 mt-20">
    <div class="container mx-auto px-4">
        <div class="text-center max-w-3xl mx-auto mb-16">
            <div class="flex items-center justify-center gap-4 mb-6">
                <a href="/" class="bg-white dark:bg-gray-800 p-3 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 text-gray-500 hover:text-primary transition-all">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                    </svg>
                </a>
                <h1 class="text-5xl font-bold dark:text-white">Market Insights & News</h1>
            </div>

            <p class="text-xl text-gray-600 dark:text-gray-300">Stay updated with the latest trends in luxury real
                estate.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12">
            <% blogs.forEach(post=> { %>
                <article
                    class="bg-white dark:bg-gray-800 rounded-[2.5rem] overflow-hidden shadow-sm hover:shadow-xl transition border border-gray-100 dark:border-gray-700 flex flex-col transition-colors duration-300">
                    <div class="h-64 overflow-hidden">
                        <img src="<%= post.featuredImage || 'https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' %>"
                            class="w-full h-full object-cover">
                    </div>
                    <div class="p-8 flex-grow flex flex-col">
                        <div class="flex items-center gap-4 mb-4">
                            <span class="text-xs font-bold uppercase tracking-widest text-primary">
                                <%= post.category || 'Real Estate' %>
                            </span>
                            <span class="text-xs text-gray-400">
                                <%= new Date(post.publishedAt).toLocaleDateString() %>
                            </span>
                        </div>
                        <h2
                            class="text-2xl font-bold mb-4 hover:text-primary transition dark:text-white dark:hover:text-primary">
                            <a href="/blog/<%= post.slug %>">
                                <%= post.title %>
                            </a>
                        </h2>
                        <p class="text-gray-600 dark:text-gray-300 mb-8 line-clamp-3">
                            <%= post.excerpt %>
                        </p>
                        <div class="mt-auto">
                            <a href="/blog/<%= post.slug %>"
                                class="font-bold text-gray-900 dark:text-white hover:text-primary dark:hover:text-primary transition flex items-center gap-2">
                                Read Article
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
                                </svg>
                            </a>
                        </div>
                    </div>
                </article>
                <% }) %>
        </div>
    </div>
</section>