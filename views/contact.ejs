<section class="py-24 bg-gray-50">
    <div class="container mx-auto px-4">
        <div class="max-w-6xl mx-auto">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16">
                <div>
                    <h1 class="text-5xl font-bold mb-8">
                        <%= content.title || 'Get in Touch' %>
                    </h1>
                    <p class="text-xl text-gray-600 mb-12">
                        <%= content.description || 'Have questions? We are here to help you find your dream home.' %>
                    </p>

                    <div class="space-y-8 mb-12">
                        <div class="flex items-start gap-6">
                            <div
                                class="w-12 h-12 bg-primary/10 rounded-2xl flex items-center justify-center text-primary shrink-0">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                                    </path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg mb-1">Office Location</h3>
                                <p class="text-gray-600">
                                    <%= content.officeLocation || '123 Luxury Way, Beverly Hills, CA' %>
                                </p>
                            </div>
                        </div>
                        <div class="flex items-start gap-6">
                            <div
                                class="w-12 h-12 bg-primary/10 rounded-2xl flex items-center justify-center text-primary shrink-0">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z">
                                    </path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="font-bold text-lg mb-1">Phone Number</h3>
                                <p class="text-gray-600">
                                    <%= settings.contactPhone %>
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="h-[300px] rounded-3xl overflow-hidden border shadow-sm">
                        <iframe
                            src="<%= content.mapEmbed || 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3153.83543450937!2d-122.4194155!3d37.7749295!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8085809c6c8f4459%3A0xb10ed6d9b5050fa5!2sTwitter%20HQ!5e0!3m2!1sen!2sus!4v1625123456789!5m2!1sen!2sus' %>"
                            width="100%" height="100%" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
                    </div>
                </div>

                <div class="bg-white p-12 rounded-[3rem] shadow-xl border border-gray-100">
                    <h2 class="text-3xl font-bold mb-8">Send a Message</h2>
                    <form id="contact-form" class="space-y-6">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label class="block text-sm font-semibold mb-2">First Name</label>
                                <input type="text" name="firstName" required
                                    class="w-full px-4 py-3 rounded-xl border border-gray-200 outline-none focus:border-primary">
                            </div>
                            <div>
                                <label class="block text-sm font-semibold mb-2">Last Name</label>
                                <input type="text" name="lastName" required
                                    class="w-full px-4 py-3 rounded-xl border border-gray-200 outline-none focus:border-primary">
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold mb-2">Email Address</label>
                            <input type="email" name="email" required
                                class="w-full px-4 py-3 rounded-xl border border-gray-200 outline-none focus:border-primary">
                        </div>
                        <div>
                            <label class="block text-sm font-semibold mb-2">Subject</label>
                            <select name="subject"
                                class="w-full px-4 py-3 rounded-xl border border-gray-200 outline-none focus:border-primary">
                                <option>General Inquiry</option>
                                <option>Buying a Property</option>
                                <option>Selling a Property</option>
                                <option>Renting</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-semibold mb-2">Message</label>
                            <textarea name="message" rows="5" required
                                class="w-full px-4 py-3 rounded-xl border border-gray-200 outline-none focus:border-primary"></textarea>
                        </div>
                        <button type="submit"
                            class="w-full bg-primary text-white py-4 rounded-xl font-bold text-lg hover:opacity-90 transition shadow-lg shadow-primary/20">
                            Send Message
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData.entries());
        data.name = `${data.firstName} ${data.lastName}`;
        data.type = 'General';

        try {
            const response = await fetch('/api/leads', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            if (response.ok) {
                showAlert('Success!', 'Your message has been sent. We will get back to you soon.', 'success');
                e.target.reset();
            } else {
                showAlert('Error', 'Something went wrong. Please try again.', 'error');
            }
        } catch (err) {
            showAlert('Error', 'Failed to connect to server.', 'error');
        }
    });
</script>