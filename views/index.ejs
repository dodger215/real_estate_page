                                                        know about buying
                                                        and renting with us.</p>
                                                </div>
                                                <div class="space-y-4">
                                                    <% (content.faq || []).forEach((item, index)=> { %>
                                                        <div
                                                            class="border border-gray-100 dark:border-gray-700 rounded-2xl overflow-hidden">
                                                            <button onclick="toggleFaq(<%= index %>)"
                                                                class="w-full px-8 py-6 flex justify-between items-center hover:bg-gray-50 dark:hover:bg-gray-800 transition bg-white dark:bg-gray-800 dark:text-white">
                                                                <span class="text-lg font-bold text-left">
                                                                    <%= item.question %>
                                                                </span>
                                                                <svg id="faq-icon-<%= index %>"
                                                                    class="w-6 h-6 transition-transform" fill="none"
                                                                    stroke="currentColor" viewBox="0 0 24 24">
                                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                                        stroke-width="2" d="M19 9l-7 7-7-7"></path>
                                                                </svg>
                                                            </button>
                                                            <div id="faq-answer-<%= index %>"
                                                                class="hidden px-8 pb-6 text-gray-600 dark:text-gray-400 leading-relaxed bg-white dark:bg-gray-800">
                                                                <%= item.answer %>
                                                            </div>
                                                        </div>
                                                        <% }) %>
