<% const layout=content.layout && content.layout.length> 0
    ? content.layout
    : ['hero', 'trust', 'property', 'features', 'location', 'contact'];
    %>

    <% layout.forEach(section=> { %>
        <% if (section==='hero' ) { %>
            <section class="relative h-[90vh] flex items-center overflow-hidden">
                <div class="absolute inset-0 z-0">
                    <img src="<%= content.hero?.backgroundImage || 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80' %>"
                        alt="Hero" class="w-full h-full object-cover">
                    <div class="absolute inset-0 bg-black/40"></div>
                </div>

                <div class="container mx-auto px-4 relative z-10">
                    <div class="max-w-3xl text-white">
                        <% if (content.hero?.showBadge) { %>
                            <span
                                class="inline-block bg-primary text-white px-4 py-1 rounded-full text-sm font-bold mb-6 uppercase tracking-wider">
                                <%= content.hero?.badgeText || 'New Listing' %>
                            </span>
                            <% } %>
                                <h1 class="text-5xl md:text-7xl font-bold mb-6 leading-tight">
                                    <%= content.hero?.headline || 'Find Your Perfect Luxury Home' %>
                                </h1>
                                <p class="text-xl md:text-2xl mb-10 text-gray-200">
                                    <%= content.hero?.subheadline
                                        || 'Experience premium living in the heart of the city with our exclusive property listings.'
                                        %>
                                </p>
                                <div class="flex flex-wrap gap-4 mb-12">
                                    <a href="#contact"
                                        class="bg-primary text-white px-8 py-4 rounded-full font-bold text-lg hover:opacity-90 transition shadow-xl shadow-primary/30">
                                        <%= content.hero?.ctaText || 'Schedule a Viewing' %>
                                    </a>
                                    <a href="/properties"
                                        class="bg-white/20 backdrop-blur-md text-white border border-white/30 px-8 py-4 rounded-full font-bold text-lg hover:bg-white/30 transition">
                                        Browse Listings
                                    </a>
                                </div>

                                <!-- Quick Search -->
                                <div
                                    class="bg-white/10 backdrop-blur-xl p-2 rounded-3xl border border-white/20 max-w-2xl">
                                    <form action="/properties" method="GET" class="flex flex-col md:flex-row gap-2">
                                        <select name="type"
                                            class="bg-transparent text-white px-6 py-3 outline-none border-r border-white/10">
                                            <option value="" class="text-black">All Types</option>
                                            <option value="Apartment" class="text-black">Apartment</option>
                                            <option value="Villa" class="text-black">Villa</option>
                                        </select>
                                        <input type="text" name="location" placeholder="Location..."
                                            class="bg-transparent text-white px-6 py-3 outline-none flex-grow placeholder:text-white/60">
                                        <button type="submit"
                                            class="bg-primary text-white px-8 py-3 rounded-2xl font-bold hover:opacity-90 transition">
                                            Search
                                        </button>
                                    </form>
                                </div>
                    </div>
                </div>
            </section>

            <!-- Featured Properties -->
            <section class="py-24 bg-white">
                <div class="container mx-auto px-4">
                    <div class="flex justify-between items-end mb-12">
                        <div>
                            <h2 class="text-4xl font-bold mb-4">Featured Properties</h2>
                            <p class="text-gray-600">Handpicked luxury listings just for you.</p>
                        </div>
                        <a href="/properties" class="text-primary font-bold hover:underline">View All Properties →</a>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                        <% featuredProperties.forEach(property=> { %>
                            <div class="group">
                                <div class="relative h-80 rounded-[2.5rem] overflow-hidden mb-6 shadow-lg">
                                    <img src="<%= property.featuredImage || 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' %>"
                                        class="w-full h-full object-cover group-hover:scale-110 transition duration-500">
                                    <div class="absolute top-6 left-6">
                                        <span
                                            class="bg-white/90 backdrop-blur-md px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider">
                                            <%= property.type %>
                                        </span>
                                    </div>
                                </div>
                                <h3 class="text-2xl font-bold mb-2">
                                    <%= property.title %>
                                </h3>
                                <p class="text-gray-500 mb-4">
                                    <%= property.location %>
                                </p>
                                <div class="flex justify-between items-center">
                                    <span class="text-2xl font-bold text-primary">₵‎<%= property.price?.toLocaleString()
                                            || property.priceRange %></span>
                                    <a href="/properties/<%= property.slug %>"
                                        class="w-12 h-12 bg-gray-900 text-white rounded-full flex items-center justify-center hover:bg-primary transition">
                                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                                        </svg>
                                    </a>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                </div>
            </section>
            <% } else if (section==='trust' ) { %>
                <!-- Trust Signals -->
                <section class="py-12 bg-white border-b">
                    <div class="container mx-auto px-4">
                        <div
                            class="flex flex-wrap justify-center items-center gap-8 md:gap-16 opacity-60 grayscale hover:grayscale-0 transition duration-500">
                            
                            <!-- <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/a/a9/Amazon_logo.svg/1024px-Amazon_logo.svg.png"
                                class="h-8">
                            <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/2/2f/Google_2015_logo.svg/1024px-Google_2015_logo.svg.png"
                                class="h-8">
                            <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/0/08/Netflix_2015_logo.svg/1024px-Netflix_2015_logo.svg.png"
                                class="h-8">
                            <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/b/b9/Slack_Technologies_Logo.svg/1024px-Slack_Technologies_Logo.svg.png"
                                class="h-8"> -->
                        </div>
                    </div>
                </section>
                <% } else if (section==='property' ) { %>
                    <!-- Property Overview -->
                    <section id="details" class="py-24 bg-white">
                        <div class="container mx-auto px-4">
                            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                                <div>
                                    <h2 class="text-4xl font-bold mb-8">
                                        <%= content.property?.title || 'Property Overview' %>
                                    </h2>
                                    <p class="text-lg text-gray-600 mb-10 leading-relaxed">
                                        <%= content.property?.description
                                            || 'This stunning property offers a perfect blend of modern architecture and comfortable living spaces.'
                                            %>
                                    </p>
                                    <div class="grid grid-cols-2 gap-8">
                                        <div class="flex items-center gap-4">
                                            <div
                                                class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary">
                                                <svg class="w-6 h-6" fill="none" stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6">
                                                    </path>
                                                </svg>
                                            </div>
                                            <div>
                                                <p class="text-sm text-gray-500">Type</p>
                                                <p class="font-bold">
                                                    <%= content.property?.type || 'Apartment' %>
                                                </p>
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-4">
                                            <div
                                                class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary">
                                                <svg class="w-6 h-6" fill="none" stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                                                    </path>
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                                </svg>
                                            </div>
                                            <div>
                                                <p class="text-sm text-gray-500">Location</p>
                                                <p class="font-bold">
                                                    <%= content.property?.location || 'Downtown' %>
                                                </p>
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-4">
                                            <div
                                                class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary">
                                                <svg class="w-6 h-6" fill="none" stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4">
                                                    </path>
                                                </svg>
                                            </div>
                                            <div>
                                                <p class="text-sm text-gray-500">Size</p>
                                                <p class="font-bold">
                                                    <%= content.property?.size || '120 sqm' %>
                                                </p>
                                            </div>
                                        </div>
                                        <div class="flex items-center gap-4">
                                            <div
                                                class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary">
                                                <svg class="w-6 h-6" fill="none" stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2"
                                                        d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z">
                                                    </path>
                                                </svg>
                                            </div>
                                            <div>
                                                <p class="text-sm text-gray-500">Price</p>
                                                <p class="font-bold text-primary text-xl">
                                                    <%= content.property?.price || 'From ₵‎250,000' %>
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="relative">
                                    <img src="https://images.unsplash.com/photo-1600607687940-4e524cb35d37?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                                        class="rounded-3xl shadow-2xl">
                                    <div
                                        class="absolute -bottom-8 -left-8 bg-white p-6 rounded-2xl shadow-xl hidden md:block">
                                        <div class="flex items-center gap-4">
                                            <div class="flex -space-x-3">
                                                <img src="https://i.pravatar.cc/40?u=1"
                                                    class="w-10 h-10 rounded-full border-2 border-white">
                                                <img src="https://i.pravatar.cc/40?u=2"
                                                    class="w-10 h-10 rounded-full border-2 border-white">
                                                <img src="https://i.pravatar.cc/40?u=3"
                                                    class="w-10 h-10 rounded-full border-2 border-white">
                                            </div>
                                            <p class="text-sm font-semibold">Joined by 500+ families</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>
                    <% } else if (section==='features' ) { %>
                        <!-- Features -->
                        <section class="py-24 bg-gray-50">
                            <div class="container mx-auto px-4">
                                <div class="text-center max-w-2xl mx-auto mb-16">
                                    <h2 class="text-4xl font-bold mb-4">Premium Amenities</h2>
                                    <p class="text-gray-600">Everything you need for a comfortable and luxurious
                                        lifestyle.</p>
                                </div>
                                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                                    <% (content.features || []).filter(f=> f.enabled).forEach(feature => { %>
                                        <div
                                            class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-md transition border border-gray-100">
                                            <div
                                                class="w-14 h-14 bg-primary/5 rounded-2xl flex items-center justify-center text-primary mb-6">
                                                <!-- Placeholder icon -->
                                                <svg class="w-8 h-8" fill="none" stroke="currentColor"
                                                    viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                        stroke-width="2" d="M5 13l4 4L19 7">
                                                    </path>
                                                </svg>
                                            </div>
                                            <h3 class="text-xl font-bold mb-3">
                                                <%= feature.name %>
                                            </h3>
                                            <p class="text-gray-500">High-quality standards and modern design for your
                                                comfort.</p>
                                        </div>
                                        <% }) %>
                                </div>
                            </div>
                        </section>
                        <% } else if (section==='location' ) { %>
                            <section class="py-24 bg-white">
                                <div class="container mx-auto px-4">
                                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                                        <div class="h-[400px] rounded-3xl overflow-hidden shadow-xl border">
                                            <iframe
                                                src="<%= content.location?.mapEmbed || 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3153.83543450937!2d-122.4194155!3d37.7749295!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8085809c6c8f4459%3A0xb10ed6d9b5050fa5!2sTwitter%20HQ!5e0!3m2!1sen!2sus!4v1625123456789!5m2!1sen!2sus' %>"
                                                width="100%" height="100%" style="border:0;" allowfullscreen=""
                                                loading="lazy"></iframe>
                                        </div>
                                        <div>
                                            <h2 class="text-4xl font-bold mb-6">Prime Location</h2>
                                            <p class="text-lg text-gray-600 mb-8">
                                                <%= content.location?.address %>
                                            </p>
                                            <p class="text-gray-500 leading-relaxed">
                                                <%= content.location?.neighborhoodDescription %>
                                            </p>
                                        </div>
                                    </div>
                                </div>
                            </section>
                            <% } else if (section==='contact' ) { %>
                                <!-- Lead Capture Form -->
                                <section id="contact" class="py-24 bg-white">
                                    <div class="container mx-auto px-4">
                                        <div
                                            class="max-w-5xl mx-auto bg-gray-900 rounded-[3rem] overflow-hidden shadow-2xl flex flex-col md:flex-row">
                                            <div class="md:w-1/2 p-12 md:p-16 text-white flex flex-col justify-center">
                                                <h2 class="text-4xl font-bold mb-6">Ready to See Your Future Home?</h2>
                                                <p class="text-gray-400 mb-8 text-lg">Fill out the form and our agent
                                                    will contact you within 24 hours to schedule a private tour.</p>
                                                <div class="space-y-6">
                                                    <div class="flex items-center gap-4">
                                                        <div
                                                            class="w-10 h-10 bg-white/10 rounded-full flex items-center justify-center text-primary">
                                                            <svg class="w-5 h-5" fill="none" stroke="currentColor"
                                                                viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                                    stroke-width="2" d="M5 13l4 4L19 7"></path>
                                                            </svg>
                                                        </div>
                                                        <span>Free consultation</span>
                                                    </div>
                                                    <div class="flex items-center gap-4">
                                                        <div
                                                            class="w-10 h-10 bg-white/10 rounded-full flex items-center justify-center text-primary">
                                                            <svg class="w-5 h-5" fill="none" stroke="currentColor"
                                                                viewBox="0 0 24 24">
                                                                <path stroke-linecap="round" stroke-linejoin="round"
                                                                    stroke-width="2" d="M5 13l4 4L19 7"></path>
                                                            </svg>
                                                        </div>
                                                        <span>Flexible payment plans</span>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="md:w-1/2 bg-white p-12 md:p-16">
                                                <form id="lead-form" class="space-y-6">
                                                    <div>
                                                        <label class="block text-sm font-semibold mb-2">Full
                                                            Name</label>
                                                        <input type="text" name="name" required
                                                            class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition">
                                                    </div>
                                                    <div>
                                                        <label class="block text-sm font-semibold mb-2">Email
                                                            Address</label>
                                                        <input type="email" name="email" required
                                                            class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition">
                                                    </div>
                                                    <div>
                                                        <label class="block text-sm font-semibold mb-2">Phone
                                                            Number</label>
                                                        <input type="tel" name="phone" required
                                                            class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition">
                                                    </div>
                                                    <div>
                                                        <label class="block text-sm font-semibold mb-2">Message
                                                            (Optional)</label>
                                                        <textarea name="message" rows="3"
                                                            class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-primary focus:ring-2 focus:ring-primary/20 outline-none transition"></textarea>
                                                    </div>
                                                    <button type="submit"
                                                        class="w-full bg-primary text-white py-4 rounded-xl font-bold text-lg hover:opacity-90 transition shadow-lg shadow-primary/20">
                                                        Get Price List & Details
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </section>
                                <% } else if (section==='testimonials' ) { %>
                                    <section class="py-24 bg-gray-50">
                                        <div class="container mx-auto px-4">
                                            <div class="text-center mb-16">
                                                <h2 class="text-4xl font-bold mb-4">What Our Clients Say</h2>
                                                <p class="text-gray-600">Real stories from real families who found their
                                                    dream home with us.</p>
                                            </div>
                                            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                                                <% (content.testimonials || []).forEach(t=> { %>
                                                    <div
                                                        class="bg-white p-10 rounded-[2.5rem] shadow-sm border border-gray-100">
                                                        <div class="flex gap-1 text-yellow-400 mb-6">
                                                            <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                                                                <path
                                                                    d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z">
                                                                </path>
                                                            </svg>
                                                            <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                                                                <path
                                                                    d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z">
                                                                </path>
                                                            </svg>
                                                            <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                                                                <path
                                                                    d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z">
                                                                </path>
                                                            </svg>
                                                            <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                                                                <path
                                                                    d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z">
                                                                </path>
                                                            </svg>
                                                            <svg class="w-5 h-5 fill-current" viewBox="0 0 20 20">
                                                                <path
                                                                    d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z">
                                                                </path>
                                                            </svg>
                                                        </div>
                                                        <p class="text-gray-600 mb-8 italic">"<%= t.content %>"</p>
                                                        <div class="flex items-center gap-4">
                                                            <img src="<%= t.avatar || 'https://i.pravatar.cc/100' %>"
                                                                class="w-12 h-12 rounded-full object-cover">
                                                            <div>
                                                                <p class="font-bold">
                                                                    <%= t.name %>
                                                                </p>
                                                                <p class="text-sm text-gray-400">
                                                                    <%= t.role %>
                                                                </p>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <% }) %>
                                            </div>
                                        </div>
                                    </section>
                                    <% } else if (section==='faq' ) { %>
                                        <section class="py-24 bg-white">
                                            <div class="container mx-auto px-4 max-w-4xl">
                                                <div class="text-center mb-16">
                                                    <h2 class="text-4xl font-bold mb-4">Frequently Asked Questions</h2>
                                                    <p class="text-gray-600">Everything you need to know about buying
                                                        and renting with us.</p>
                                                </div>
                                                <div class="space-y-4">
                                                    <% (content.faq || []).forEach((item, index)=> { %>
                                                        <div class="border border-gray-100 rounded-2xl overflow-hidden">
                                                            <button onclick="toggleFaq(<%= index %>)"
                                                                class="w-full px-8 py-6 flex justify-between items-center hover:bg-gray-50 transition">
                                                                <span class="text-lg font-bold text-left">
                                                                    <%= item.question %>
                                                                </span>
                                                                <svg id="faq-icon-<%= index %>"
                                                                    class="w-6 h-6 transition-transform" fill="none"
                                                                    stroke="currentColor" viewBox="0 0 24 24">
                                                                    <path stroke-linecap="round" stroke-linejoin="round"
                                                                        stroke-width="2" d="M19 9l-7 7-7-7"></path>
                                                                </svg>
                                                            </button>
                                                            <div id="faq-answer-<%= index %>"
                                                                class="hidden px-8 pb-6 text-gray-600 leading-relaxed">
                                                                <%= item.answer %>
                                                            </div>
                                                        </div>
                                                        <% }) %>
                                                </div>
                                            </div>
                                        </section>
                                        <script>
                                            function toggleFaq(index) {
                                                const answer = document.getElementById(`faq-answer-${index}`);
                                                const icon = document.getElementById(`faq-icon-${index}`);
                                                answer.classList.toggle('hidden');
                                                icon.classList.toggle('rotate-180');
                                            }
                                        </script>
                                        <% } %>
                                            <% }) %>

                                                <script>
                                                    document.getElementById('lead-form')?.addEventListener('submit', async (e) => {
                                                        e.preventDefault();
                                                        const formData = new FormData(e.target);
                                                        const data = Object.fromEntries(formData.entries());

                                                        try {
                                                            const response = await fetch('/api/leads', {
                                                                method: 'POST',
                                                                headers: { 'Content-Type': 'application/json' },
                                                                body: JSON.stringify(data)
                                                            });

                                                            if (response.ok) {
                                                                showAlert('Success!', 'Your inquiry has been sent. We will contact you soon.', 'success');
                                                                e.target.reset();
                                                            } else {
                                                                showAlert('Error', 'Something went wrong. Please try again.', 'error');
                                                            }
                                                        } catch (err) {
                                                            showAlert('Error', 'Failed to connect to server.', 'error');
                                                        }
                                                    });
                                                </script>