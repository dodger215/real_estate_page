                                                                            class="p-4 rounded-2xl bg-gray-50 dark:bg-gray-800 border-2 border-transparent peer-checked:border-primary peer-checked:bg-primary/5 transition-all text-center">
                                                                            <span
                                                                                class="text-sm font-bold dark:text-white">Land</span>
                                                                        </div>
                                                                    </label>
                                                                </div>
                                                            </div>

                                                            <div>
                                                                <label
                                                                    class="block text-xs font-black text-gray-400 uppercase tracking-[0.2em] mb-4">Location</label>
                                                                <div class="relative group">
                                                                    <input type="text" name="location"
                                                                        placeholder="City, Area or Landmark..."
                                                                        class="w-full h-16 px-6 rounded-2xl bg-gray-50 dark:bg-gray-800 border-2 border-transparent focus:border-primary focus:bg-white dark:focus:bg-gray-900 dark:text-white font-bold transition-all outline-none">
                                                                    <svg class="absolute right-6 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400"
                                                                        fill="none" stroke="currentColor"
                                                                        viewBox="0 0 24 24">
                                                                        <path stroke-linecap="round"
                                                                            stroke-linejoin="round" stroke-width="2"
                                                                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                                                                        </path>
                                                                        <path stroke-linecap="round"
                                                                            stroke-linejoin="round" stroke-width="2"
                                                                            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                                                    </svg>
                                                                </div>
                                                            </div>

                                                            <button type="submit"
                                                                class="w-full h-20 bg-primary text-white rounded-[2rem] font-black uppercase tracking-[0.2em] shadow-2xl shadow-primary/40 active:scale-[0.98] transition-all">
                                                                Show Properties
                                                            </button>
                                                        </form>
                                                    </div>
                                                </div>