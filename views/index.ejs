                                        <script>
                                            function toggleFaq(index) {
                                                const answer = document.getElementById(`faq-answer-${index}`);
                                                const icon = document.getElementById(`faq-icon-${index}`);
                                                answer.classList.toggle('hidden');
                                                icon.classList.toggle('rotate-180');
                                            }
                                        </script>
                                        <% } %>
                                            <% }) %>

                                                <script>
                                                    document.getElementById('lead-form')?.addEventListener('submit', async (e) => {
                                                        e.preventDefault();
                                                        const formData = new FormData(e.target);
                                                        const data = Object.fromEntries(formData.entries());

                                                        try {
                                                            const response = await fetch('/api/leads', {
                                                                method: 'POST',
                                                                headers: { 'Content-Type': 'application/json' },
                                                                body: JSON.stringify(data)
                                                            });

                                                            if (response.ok) {
                                                                showAlert('Success!', 'Your inquiry has been sent. We will contact you soon.', 'success');
                                                                e.target.reset();
                                                            } else {
                                                                showAlert('Error', 'Something went wrong. Please try again.', 'error');
                                                            }
                                                        } catch (err) {
                                                            showAlert('Error', 'Failed to connect to server.', 'error');
                                                        }
                                                    });

                                                    // Home Search Bottom Sheet Logic
                                                    function toggleHomeSearch(show) {
                                                        const backdrop = document.getElementById('home-search-backdrop');
                                                        const sheet = document.getElementById('home-search-sheet');

                                                        if (show) {
                                                            backdrop.classList.remove('pointer-events-none', 'opacity-0');
                                                            backdrop.classList.add('opacity-100');
                                                            sheet.classList.remove('translate-y-full');
                                                            document.body.style.overflow = 'hidden';
                                                        } else {
                                                            backdrop.classList.remove('opacity-100');
                                                            backdrop.classList.add('opacity-0');
                                                            sheet.classList.add('translate-y-full');
                                                            document.body.style.overflow = '';
                                                            setTimeout(() => {
                                                                backdrop.classList.add('pointer-events-none');
                                                            }, 500);
                                                        }
                                                    }

                                                    // Simple Swipe Down to Close
                                                    const homeSearchSheet = document.getElementById('home-search-sheet');
                                                    let homeSearchStartY = 0;

                                                    homeSearchSheet?.addEventListener('touchstart', (e) => {
                                                        homeSearchStartY = e.touches[0].clientY;
                                                    });

                                                    homeSearchSheet?.addEventListener('touchmove', (e) => {
                                                        const touchY = e.touches[0].clientY;
                                                        const diff = touchY - homeSearchStartY;
                                                        if (diff > 0) {
                                                            homeSearchSheet.style.transform = `translateY(${diff}px)`;
                                                        }
                                                    });

                                                    homeSearchSheet?.addEventListener('touchend', (e) => {
                                                        const touchY = e.changedTouches[0].clientY;
                                                        const diff = touchY - homeSearchStartY;
                                                        if (diff > 100) {
                                                            toggleHomeSearch(false);
                                                        } else {
                                                            homeSearchSheet.style.transform = '';
                                                        }
                                                    });
                                                </script>

                                                <!-- Home Search Bottom Sheet -->
                                                <div id="home-search-backdrop" onclick="toggleHomeSearch(false)"
                                                    class="md:hidden fixed inset-0 bg-gray-900/90 backdrop-blur-xl z-[100] opacity-0 pointer-events-none transition-all duration-500">
                                                </div>

                                                <div id="home-search-sheet"
                                                    class="md:hidden fixed bottom-0 left-0 right-0 bg-white dark:bg-gray-900 rounded-t-[3rem] z-[110] transform translate-y-full transition-transform duration-500 ease-out shadow-[0_-20px_80px_rgba(0,0,0,0.4)] border-t border-white/5">
                                                    <!-- Handle -->
                                                    <div class="w-12 h-1.5 bg-gray-200 dark:bg-gray-800 rounded-full mx-auto mt-4 mb-8"
                                                        onclick="toggleHomeSearch(false)"></div>

                                                    <div class="px-8 pb-16">
                                                        <h2
                                                            class="text-4xl font-black text-gray-900 dark:text-white uppercase tracking-tighter mb-10">
                                                            Find Your Home</h2>

                                                        <form action="/properties" method="GET" class="space-y-10">
                                                            <div>
                                                                <label
                                                                    class="block text-xs font-black text-gray-400 uppercase tracking-[0.2em] mb-4">Property
                                                                    Type</label>
                                                                <div class="grid grid-cols-2 gap-3">
                                                                    <label class="relative group cursor-pointer">
                                                                        <input type="radio" name="type" value="" checked
                                                                            class="peer sr-only">
                                                                        <div
                                                                            class="p-4 rounded-2xl bg-gray-50 dark:bg-gray-800 border-2 border-transparent peer-checked:border-primary peer-checked:bg-primary/5 transition-all text-center">
                                                                            <span
                                                                                class="text-sm font-bold dark:text-white">All
                                                                                Types</span>
                                                                        </div>
                                                                    </label>
                                                                    <label class="relative group cursor-pointer">
                                                                        <input type="radio" name="type"
                                                                            value="Apartment" class="peer sr-only">
                                                                        <div
                                                                            class="p-4 rounded-2xl bg-gray-50 dark:bg-gray-800 border-2 border-transparent peer-checked:border-primary peer-checked:bg-primary/5 transition-all text-center">
                                                                            <span
                                                                                class="text-sm font-bold dark:text-white">Apartment</span>
                                                                        </div>
                                                                    </label>
                                                                    <label class="relative group cursor-pointer">
                                                                        <input type="radio" name="type" value="Villa"
                                                                            class="peer sr-only">
                                                                        <div
                                                                            class="p-4 rounded-2xl bg-gray-50 dark:bg-gray-800 border-2 border-transparent peer-checked:border-primary peer-checked:bg-primary/5 transition-all text-center">
                                                                            <span
                                                                                class="text-sm font-bold dark:text-white">Villa</span>
                                                                        </div>
                                                                    </label>
                                                                    <label class="relative group cursor-pointer">
                                                                        <input type="radio" name="type" value="Land"
