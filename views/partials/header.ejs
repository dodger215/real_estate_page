<!-- Sleek Black Rounded Navbar -->
<header class="fixed top-0 left-0 right-0 z-50 p-6 pointer-events-none">
    <div
        class="max-w-7xl mx-auto bg-gray-900/95 backdrop-blur-md border border-white/10 rounded-[2rem] shadow-2xl px-6 md:px-8 py-4 md:py-5 flex items-center justify-between pointer-events-auto transition-all duration-300">

        <!-- Logo Section -->
        <div class="flex items-center gap-3">
            <a href="/" class="flex items-center gap-3 group">
                <% if (settings.logo) { %>
                    <img src="<%= settings.logo %>" alt="<%= settings.siteName %>"
                        class="h-8 md:h-10 transition-transform group-hover:scale-110">
                    <% } else { %>
                        <span
                            class="text-xl md:text-2xl font-bold text-white tracking-tight group-hover:text-primary transition-colors uppercase">
                            <%= settings.siteName || 'ESTATE' %>
                        </span>
                        <% } %>
            </a>
        </div>

        <!-- Desktop Navigation -->
        <nav class="hidden lg:flex items-center gap-1">
            <% if (typeof isPublicView !=='undefined' && isPublicView) { %>
                <a href="/"
                    class="text-gray-300 hover:text-white transition-all px-6 py-2.5 rounded-full hover:bg-white/10 font-medium flex items-center gap-2">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6">
                        </path>
                    </svg>
                    Home
                </a>
                <% } else { %>
                    <a href="/"
                        class="text-gray-300 hover:text-white transition-all px-5 py-2.5 rounded-full hover:bg-white/10 font-semibold tracking-wide text-sm uppercase">Home</a>
                    <a href="/properties"
                        class="text-gray-300 hover:text-white transition-all px-5 py-2.5 rounded-full hover:bg-white/10 font-semibold tracking-wide text-sm uppercase">Properties</a>
                    <a href="/about"
                        class="text-gray-300 hover:text-white transition-all px-5 py-2.5 rounded-full hover:bg-white/10 font-semibold tracking-wide text-sm uppercase">About</a>
                    <a href="/blog"
                        class="text-gray-300 hover:text-white transition-all px-5 py-2.5 rounded-full hover:bg-white/10 font-semibold tracking-wide text-sm uppercase">Blog</a>
                    <a href="/contact"
                        class="text-gray-300 hover:text-white transition-all px-5 py-2.5 rounded-full hover:bg-white/10 font-semibold tracking-wide text-sm uppercase">Contact</a>
                    <% } %>
        </nav>

        <!-- Actions -->
        <div class="flex items-center gap-3 md:gap-4">
            <!-- Theme Toggle -->
            <button onclick="toggleTheme()"
                class="p-2.5 rounded-full bg-white/5 border border-white/10 text-gray-400 hover:text-white hover:bg-white/10 transition-all">
                <svg class="w-5 h-5 hidden dark:block text-yellow-500" fill="none" stroke="currentColor"
                    viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z">
                    </path>
                </svg>
                <svg class="w-5 h-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z">
                    </path>
                </svg>
            </button>

            <!-- CTA Button -->
            <% if (!(typeof isPublicView !=='undefined' && isPublicView)) { %>
                <a href="#contact"
                    class="hidden sm:block bg-primary text-white px-6 py-2.5 md:py-3 rounded-full font-black hover:brightness-110 transition-all shadow-lg shadow-primary/30 text-xs tracking-[0.1em] uppercase">
                    Book Viewing
                </a>
                <% } %>

                    <!-- Mobile Hamburger -->
                    <button id="mobile-menu-btn" onclick="toggleMobileMenu(true)"
                        class="lg:hidden p-2.5 rounded-full bg-white/5 border border-white/10 text-white hover:bg-white/10 transition-all">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M4 6h16M4 12h16m-7 6h7"></path>
                        </svg>
                    </button>
        </div>
    </div>
</header>

<!-- Mobile Navigation Menu -->
<div id="mobile-menu" class="fixed inset-0 z-[100] lg:hidden opacity-0 pointer-events-none transition-all duration-300">
    <!-- Backdrop -->
    <div class="absolute inset-0 bg-gray-900/90 backdrop-blur-xl" onclick="toggleMobileMenu(false)"></div>

    <!-- Menu Content -->
    <div
        class="absolute inset-y-0 right-0 w-[80%] max-w-sm bg-gray-900 shadow-2xl transform translate-x-full transition-transform duration-500 ease-out border-l border-white/5">
        <div class="flex flex-col h-full p-10">
            <div class="flex items-center justify-between mb-16">
                <span class="text-2xl font-black text-white uppercase tracking-tighter">Menu</span>
                <button onclick="toggleMobileMenu(false)"
                    class="p-3 bg-white/5 rounded-full text-gray-400 hover:text-white transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12">
                        </path>
                    </svg>
                </button>
            </div>

            <nav class="flex flex-col gap-6">
                <% const navLinks=[ { name: 'Home' , href: '/' }, { name: 'Properties' , href: '/properties' }, {
                    name: 'About' , href: '/about' }, { name: 'Blog' , href: '/blog' }, { name: 'Contact' ,
                    href: '/contact' } ]; %>

                    <% if (typeof isPublicView !=='undefined' && isPublicView) { %>
                        <a href="/"
                            class="text-4xl font-black text-white hover:text-primary transition-colors flex items-center justify-between">
                            HOME
                            <svg class="w-8 h-8 opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                            </svg>
                        </a>
                        <% } else { %>
                            <% navLinks.forEach(link=> { %>
                                <a href="<%= link.href %>"
                                    class="text-4xl font-black text-white hover:text-primary transition-colors flex items-center justify-between group">
                                    <%= link.name.toUpperCase() %>
                                        <svg class="w-8 h-8 opacity-0 group-hover:opacity-100 transition-all transform -translate-x-4 group-hover:translate-x-0"
                                            fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                                        </svg>
                                </a>
                                <% }) %>
                                    <% } %>
            </nav>

            <div class="mt-auto pt-10 border-t border-white/5">
                <div class="flex items-center gap-6">
                    <a href="#" class="text-sm font-bold text-gray-500 hover:text-white transition-colors">INSTAGRAM</a>
                    <a href="#" class="text-sm font-bold text-gray-500 hover:text-white transition-colors">FACEBOOK</a>
                    <a href="#" class="text-sm font-bold text-gray-500 hover:text-white transition-colors">X</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function toggleTheme() {
        if (document.documentElement.classList.contains('dark')) {
            document.documentElement.classList.remove('dark');
            localStorage.theme = 'light';
        } else {
            document.documentElement.classList.add('dark');
            localStorage.theme = 'dark';
        }
    }

    function toggleMobileMenu(show) {
        const menu = document.getElementById('mobile-menu');
        const content = menu.querySelector('div:last-child');

        if (show) {
            menu.classList.remove('opacity-0', 'pointer-events-none');
            menu.classList.add('opacity-100');
            content.classList.remove('translate-x-full');
            document.body.style.overflow = 'hidden';
        } else {
            menu.classList.remove('opacity-100');
            menu.classList.add('opacity-0');
            content.classList.add('translate-x-full');
            document.body.style.overflow = '';
            setTimeout(() => {
                menu.classList.add('pointer-events-none');
            }, 500);
        }
    }
</script>