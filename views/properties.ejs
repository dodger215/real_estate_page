<section class="py-12 bg-gray-50">
    <div class="container mx-auto px-4">
        <h1 class="text-4xl font-bold mb-8">Our Properties</h1>

        <!-- Filters -->
        <form action="/properties" method="GET"
            class="bg-white p-6 rounded-2xl shadow-sm mb-12 grid grid-cols-1 md:grid-cols-4 gap-4">
            <div>
                <label class="block text-sm font-semibold mb-2">Type</label>
                <select name="type" class="w-full px-4 py-2 rounded-xl border border-gray-200 outline-none">
                    <option value="">All Types</option>
                    <option value="Apartment" <%= filters.type==='Apartment' ? 'selected' : '' %>>Apartment</option>
                    <option value="Villa" <%= filters.type==='Villa' ? 'selected' : '' %>>Villa</option>
                    <option value="Land" <%= filters.type==='Land' ? 'selected' : '' %>>Land</option>
                    <option value="Commercial" <%= filters.type==='Commercial' ? 'selected' : '' %>>Commercial</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-semibold mb-2">Status</label>
                <select name="status" class="w-full px-4 py-2 rounded-xl border border-gray-200 outline-none">
                    <option value="">All Status</option>
                    <option value="Ready" <%= filters.status==='Ready' ? 'selected' : '' %>>Ready</option>
                    <option value="Off-plan" <%= filters.status==='Off-plan' ? 'selected' : '' %>>Off-plan</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-semibold mb-2">Min Price</label>
                <input type="number" name="minPrice" value="<%= filters.minPrice || '' %>" placeholder="Min"
                    class="w-full px-4 py-2 rounded-xl border border-gray-200 outline-none">
            </div>
            <div>
                <label class="block text-sm font-semibold mb-2">Max Price</label>
                <input type="number" name="maxPrice" value="<%= filters.maxPrice || '' %>" placeholder="Max"
                    class="w-full px-4 py-2 rounded-xl border border-gray-200 outline-none">
            </div>
            <div class="flex items-end">
                <button type="submit"
                    class="w-full bg-primary text-white py-2 rounded-xl font-bold hover:opacity-90 transition">
                    Filter Results
                </button>
            </div>
        </form>

        <!-- Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            <% properties.forEach(property=> { %>
                <div
                    class="bg-white rounded-3xl overflow-hidden shadow-sm hover:shadow-xl transition group border border-gray-100">
                    <div class="relative h-64 overflow-hidden">
                        <img src="<%= property.featuredImage || 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' %>"
                            class="w-full h-full object-cover group-hover:scale-110 transition duration-500">
                        <div class="absolute top-4 left-4 flex gap-2">
                            <span
                                class="bg-white/90 backdrop-blur-md px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider">
                                <%= property.type %>
                            </span>
                            <span
                                class="bg-primary text-white px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider">
                                <%= property.status %>
                            </span>
                        </div>
                    </div>
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-2">
                            <%= property.title %>
                        </h3>
                        <p class="text-gray-500 text-sm mb-4 flex items-center gap-1">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                                </path>
                            </svg>
                            <%= property.location %>
                        </p>
                        <div class="flex justify-between items-center pt-4 border-t">
                            <span class="text-primary font-bold text-xl">₵‎<%= property.price?.toLocaleString() ||
                                    property.priceRange %></span>
                            <a href="/properties/<%= property.slug %>"
                                class="text-gray-900 font-semibold hover:text-primary transition">View Details →</a>
                        </div>
                    </div>
                </div>
                <% }) %>
        </div>

        <% if (properties.length===0) { %>
            <div class="text-center py-24">
                <p class="text-gray-500 text-xl">No properties found matching your criteria.</p>
            </div>
            <% } %>
    </div>
</section>