<section class="py-12 bg-gray-50 dark:bg-gray-900 transition-colors duration-300 mt-20 relative min-h-screen">
    <div class="container mx-auto px-4">
        <div class="flex flex-col lg:flex-row gap-8">

            <!-- Desktop Filter Sidebar (Left Side) -->
            <aside class="hidden lg:block w-80 shrink-0">
                <div
                    class="sticky top-32 bg-white dark:bg-gray-800 p-8 rounded-[2.5rem] shadow-xl border border-gray-100 dark:border-gray-700">
                    <h2
                        class="text-2xl font-black mb-6 dark:text-white tracking-tight uppercase flex items-center gap-3">
                        <span class="w-8 h-1 bg-primary rounded-full"></span>
                        Filters
                    </h2>

                    <form action="/properties" method="GET" class="space-y-6">
                        <div>
                            <label
                                class="block text-xs font-bold mb-3 dark:text-gray-400 uppercase tracking-widest transition-colors">Type</label>
                            <select name="type"
                                class="w-full h-12 px-4 rounded-2xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 dark:text-white focus:ring-4 focus:ring-primary/20 outline-none transition-all appearance-none">
                                <option value="">All Types</option>
                                <option value="Apartment" <%=filters.type==='Apartment' ? 'selected' : '' %>>Apartment
                                </option>
                                <option value="Villa" <%=filters.type==='Villa' ? 'selected' : '' %>>Villa</option>
                                <option value="Land" <%=filters.type==='Land' ? 'selected' : '' %>>Land</option>
                                <option value="Commercial" <%=filters.type==='Commercial' ? 'selected' : '' %>
                                    >Commercial</option>
                            </select>
                        </div>

                        <div>
                            <label
                                class="block text-xs font-bold mb-3 dark:text-gray-400 uppercase tracking-widest">Status</label>
                            <select name="status"
                                class="w-full h-12 px-4 rounded-2xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 dark:text-white focus:ring-4 focus:ring-primary/20 outline-none transition-all appearance-none">
                                <option value="">All Status</option>
                                <option value="Ready" <%=filters.status==='Ready' ? 'selected' : '' %>>Ready</option>
                                <option value="Off-plan" <%=filters.status==='Off-plan' ? 'selected' : '' %>>Off-plan
                                </option>
                            </select>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label
                                    class="block text-xs font-bold mb-3 dark:text-gray-400 uppercase tracking-widest">Min
                                    Price</label>
                                <input type="number" name="minPrice" value="<%= filters.minPrice || '' %>"
                                    placeholder="₵ Min"
                                    class="w-full h-12 px-4 rounded-2xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 dark:text-white focus:ring-4 focus:ring-primary/20 outline-none transition-all placeholder:text-gray-400">
                            </div>
                            <div>
                                <label
                                    class="block text-xs font-bold mb-3 dark:text-gray-400 uppercase tracking-widest">Max
                                    Price</label>
                                <input type="number" name="maxPrice" value="<%= filters.maxPrice || '' %>"
                                    placeholder="₵ Max"
                                    class="w-full h-12 px-4 rounded-2xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 dark:text-white focus:ring-4 focus:ring-primary/20 outline-none transition-all placeholder:text-gray-400">
                            </div>
                        </div>

                        <button type="submit"
                            class="w-full h-14 bg-gray-900 dark:bg-primary text-white py-2 rounded-2xl font-black uppercase tracking-widest hover:brightness-110 active:scale-95 transition-all shadow-xl shadow-gray-200 dark:shadow-primary/20 mt-4">
                            Apply Filters
                        </button>

                        <% if (Object.keys(filters).length> 0) { %>
                            <a href="/properties"
                                class="block text-center text-xs font-bold text-gray-400 hover:text-primary transition-colors py-2 uppercase tracking-widest">
                                Clear All
                            </a>
                            <% } %>
                    </form>
                </div>
            </aside>

            <!-- Main Content Area -->
            <div class="flex-1">
                <div class="flex items-center justify-between mb-10">
                    <div>
                        <h1 class="text-4xl md:text-5xl font-black dark:text-white tracking-tight leading-tight">Our
                            Properties</h1>
                        <p class="text-gray-500 dark:text-gray-400 mt-2 font-medium tracking-wide">
                            <%= properties.length %> listings available
                        </p>
                    </div>
                </div>

                <!-- Property Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-2 2xl:grid-cols-3 gap-10">
                    <% properties.forEach(property=> { %>
                        <div
                            class="bg-white dark:bg-gray-800 rounded-[2.5rem] overflow-hidden shadow-xl hover:shadow-2xl transition-all duration-500 group border border-gray-100 dark:border-gray-700/50">
                            <div class="relative h-72 overflow-hidden">
                                <img src="<%= property.featuredImage || 'https://images.unsplash.com/photo-1600585154340-be6161a56a0c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' %>"
                                    class="w-full h-full object-cover group-hover:scale-110 transition duration-700">

                                <div class="absolute top-6 left-6 flex flex-col gap-3">
                                    <span
                                        class="bg-white/90 dark:bg-gray-900/90 backdrop-blur-md px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-[0.2em] text-gray-900 dark:text-white border border-white/20">
                                        <%= property.type %>
                                    </span>
                                    <span
                                        class="bg-primary text-white px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-[0.2em] shadow-lg shadow-primary/40">
                                        <%= property.status %>
                                    </span>
                                </div>

                                <div
                                    class="absolute bottom-6 left-6 right-6 translate-y-20 group-hover:translate-y-0 transition-transform duration-500">
                                    <a href="/properties/<%= property.slug %>"
                                        class="block w-full text-center bg-white/20 backdrop-blur-xl border border-white/30 text-white font-black py-4 rounded-2xl uppercase tracking-widest text-xs hover:bg-white hover:text-gray-900 transition-colors">
                                        View Property
                                    </a>
                                </div>
                            </div>

                            <div class="p-8">
                                <div class="flex justify-between items-start mb-4">
                                    <h3
                                        class="text-2xl font-black dark:text-white tracking-tight group-hover:text-primary transition-colors">
                                        <%= property.title %>
                                    </h3>
                                </div>

                                <p
                                    class="text-gray-500 dark:text-gray-400 text-sm mb-6 flex items-center gap-2 font-medium">
                                    <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor"
                                        viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                                        </path>
                                    </svg>
                                    <%= property.location %>
                                </p>

                                <div
                                    class="flex justify-between items-center pt-6 border-t border-gray-100 dark:border-gray-700">
                                    <span class="text-gray-900 dark:text-white font-black text-2xl tracking-tighter">
                                        ₵<%= property.price?.toLocaleString() || property.priceRange %>
                                    </span>
                                    <div class="flex gap-2 text-gray-400">
                                        <div
                                            class="flex items-center gap-1.5 bg-gray-50 dark:bg-gray-700/50 px-3 py-1.5 rounded-xl border border-gray-100 dark:border-gray-600">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                    d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6">
                                                </path>
                                            </svg>
                                            <span class="text-[10px] font-bold uppercase tracking-widest">
                                                <%= property.beds || 3 %> BD
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <% }) %>
                </div>

                <% if (properties.length===0) { %>
                    <div
                        class="text-center py-32 bg-white dark:bg-gray-800 rounded-[3rem] shadow-sm border border-gray-100 dark:border-gray-700">
                        <div
                            class="w-24 h-24 bg-gray-50 dark:bg-gray-900 rounded-full flex items-center justify-center mx-auto mb-6">
                            <svg class="w-10 h-10 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10">
                                </path>
                            </svg>
                        </div>
                        <h2 class="text-2xl font-black dark:text-white uppercase tracking-widest">No Matches Found</h2>
                        <p class="text-gray-500 dark:text-gray-400 mt-2 font-medium">Try adjusting your filters or
                            search criteria.</p>
                        <a href="/properties"
                            class="mt-8 inline-block px-10 py-4 bg-primary text-white font-black rounded-2xl uppercase tracking-widest text-xs shadow-lg shadow-primary/20">Clear
                            All Filters</a>
                    </div>
                    <% } %>
            </div>
        </div>
    </div>

    <!-- Mobile Floating Filter Button (FAB) -->
    <div class="lg:hidden fixed bottom-10 left-1/2 -translate-x-1/2 z-50">
        <button onclick="toggleBottomSheet(true)"
            class="flex items-center gap-3 bg-gray-900 dark:bg-white text-white dark:text-gray-900 px-8 py-4 rounded-full shadow-2xl font-black uppercase tracking-widest text-xs border border-white/10 active:scale-90 transition-all">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4">
                </path>
            </svg>
            Show Filters
        </button>
    </div>

    <!-- Mobile Bottom Sheet Filters -->
    <div id="filter-backdrop" onclick="toggleBottomSheet(false)"
        class="lg:hidden fixed inset-0 bg-gray-900/60 backdrop-blur-sm z-[60] opacity-0 pointer-events-none transition-opacity duration-300">
    </div>

    <div id="filter-sheet"
        class="lg:hidden fixed bottom-0 left-0 right-0 bg-white dark:bg-gray-800 rounded-t-[3rem] z-[70] transform translate-y-full transition-transform duration-500 ease-out shadow-[0_-20px_50px_rgba(0,0,0,0.1)]">
        <!-- Sheet Handle -->
        <div class="w-16 h-1.5 bg-gray-200 dark:bg-gray-700 rounded-full mx-auto mt-4 mb-6"
            onclick="toggleBottomSheet(false)"></div>

        <div class="px-8 pb-12 pt-4">
            <div class="flex items-center justify-between mb-8">
                <h2 class="text-3xl font-black text-gray-900 dark:text-white uppercase tracking-tighter">Filter
                    Properties</h2>
                <button onclick="toggleBottomSheet(false)"
                    class="p-2 bg-gray-100 dark:bg-gray-700 rounded-full text-gray-500">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12">
                        </path>
                    </svg>
                </button>
            </div>

            <form action="/properties" method="GET" class="space-y-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-xs font-black mb-3 text-gray-400 uppercase tracking-[0.2em]">Property
                            Type</label>
                        <select name="type"
                            class="w-full h-16 px-6 rounded-2xl bg-gray-50 dark:bg-gray-900 border-none dark:text-white font-bold transition-all">
                            <option value="">All Types</option>
                            <option value="Apartment" <%=filters.type==='Apartment' ? 'selected' : '' %>>Apartment
                            </option>
                            <option value="Villa" <%=filters.type==='Villa' ? 'selected' : '' %>>Villa</option>
                            <option value="Land" <%=filters.type==='Land' ? 'selected' : '' %>>Land</option>
                            <option value="Commercial" <%=filters.type==='Commercial' ? 'selected' : '' %>>Commercial
                            </option>
                        </select>
                    </div>

                    <div>
                        <label
                            class="block text-xs font-black mb-3 text-gray-400 uppercase tracking-[0.2em]">Status</label>
                        <select name="status"
                            class="w-full h-16 px-6 rounded-2xl bg-gray-50 dark:bg-gray-900 border-none dark:text-white font-bold transition-all">
                            <option value="">All Status</option>
                            <option value="Ready" <%=filters.status==='Ready' ? 'selected' : '' %>>Ready</option>
                            <option value="Off-plan" <%=filters.status==='Off-plan' ? 'selected' : '' %>>Off-plan
                            </option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-xs font-black mb-3 text-gray-400 uppercase tracking-[0.2em]">Price
                            Range (GH₵)</label>
                        <div class="flex gap-4">
                            <input type="number" name="minPrice" value="<%= filters.minPrice || '' %>" placeholder="Min"
                                class="w-1/2 h-16 px-6 rounded-2xl bg-gray-50 dark:bg-gray-900 border-none dark:text-white font-bold placeholder:text-gray-300 transition-all">
                            <input type="number" name="maxPrice" value="<%= filters.maxPrice || '' %>" placeholder="Max"
                                class="w-1/2 h-16 px-6 rounded-2xl bg-gray-50 dark:bg-gray-900 border-none dark:text-white font-bold placeholder:text-gray-300 transition-all">
                        </div>
                    </div>
                </div>

                <div class="pt-6 flex gap-4">
                    <a href="/properties"
                        class="flex-1 h-16 bg-gray-100 dark:bg-gray-700 text-gray-900 dark:text-white rounded-2xl font-black uppercase tracking-widest text-xs flex items-center justify-center">Reset</a>
                    <button type="submit"
                        class="flex-[2] h-16 bg-primary text-white rounded-2xl font-black uppercase tracking-widest text-xs shadow-xl shadow-primary/30">Apply
                        Filters</button>
                </div>
            </form>
        </div>
    </div>
</section>

<script>
    function toggleBottomSheet(show) {
        const backdrop = document.getElementById('filter-backdrop');
        const sheet = document.getElementById('filter-sheet');

        if (show) {
            backdrop.classList.remove('pointer-events-none', 'opacity-0');
            backdrop.classList.add('opacity-100');
            sheet.classList.remove('translate-y-full');
            document.body.style.overflow = 'hidden';
        } else {
            backdrop.classList.remove('opacity-100');
            backdrop.classList.add('opacity-0');
            sheet.classList.add('translate-y-full');
            document.body.style.overflow = '';
            setTimeout(() => {
                backdrop.classList.add('pointer-events-none');
            }, 300);
        }
    }

    // Close on swipe down (simple version)
    let touchStartY = 0;
    const sheet = document.getElementById('filter-sheet');

    sheet.addEventListener('touchstart', (e) => {
        touchStartY = e.touches[0].clientY;
    });

    sheet.addEventListener('touchmove', (e) => {
        const touchY = e.touches[0].clientY;
        const diff = touchY - touchStartY;
        if (diff > 0 && e.target.closest('#filter-sheet')) {
            sheet.style.transform = `translateY(${diff}px)`;
        }
    });

    sheet.addEventListener('touchend', (e) => {
        const touchY = e.changedTouches[0].clientY;
        const diff = touchY - touchStartY;
        if (diff > 100) {
            toggleBottomSheet(false);
        } else {
            sheet.style.transform = '';
        }
    });
</script>